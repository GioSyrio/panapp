ss=\"subq\"><span class=\"subq-num\">β)</span> <span class=\"subq-text\">περιορίστηκαν</span></div>\n<div class=\"subq\"><span class=\"subq-num\">γ)</span> <span class=\"subq-text\">έμειναν αμετάβλητες</span></div>\n<div class=\"subq\"><span class=\"subq-num\">δ)</span> <span class=\"subq-text\">καταργήθηκαν.</span></div>\n<div class=\"subq\"><span class=\"subq-num\">2.Με)</span> <span class=\"subq-text\">το σύνταγμα του 1864 καθιερωνόταν η αρχή της:</span></div>\n<div class=\"subq\"><span class=\"subq-num\">α)</span> <span class=\"subq-text\">λαϊκής συμμετοχής</span></div>\n<div class=\"subq\"><span class=\"subq-num\">β)</span> <span class=\"subq-text\">λαϊκής κυριαρχίας</span></div>\n<div class=\"subq\"><span class=\"subq-num\">γ)</span> <span class=\"subq-text\">λαϊκής βάσης</span></div>\n<div class=\"subq\"><span class=\"subq-num\">δ)</span> <span class=\"subq-text\">δεδηλωμένης.</span></div>\n<div class=\"subq\"><span class=\"subq-num\">3.Οι)</span> <span class=\"subq-text\">φορείς των νέων ιδεών, στις εκλογές της 8ης Αυγούστου 1910, συσπειρώθηκαν γύρω από το αίτημα:</span></div>\n<div class=\"subq\"><span class=\"subq-num\">α)</span> <span class=\"subq-text\">της ανόρθωσης</span></div>\n<div class=\"subq\"><span class=\"subq-num\">β)</span> <span class=\"subq-text\">της ανασυγκρότησης</span></div>\n<div class=\"subq\"><span class=\"subq-num\">γ)</span> <span class=\"subq-text\">της αλλαγής</span></div>\n<div class=\"subq\"><span class=\"subq-num\">δ)</span> <span class=\"subq-text\">του εκσυγχρονισμού.</span></div>\n<div class=\"subq\"><span class=\"subq-num\">4.Η)</span> <span class=\"subq-text\">αστική στέγαση των προσφύγων του 1922:</span></div>\n<div class=\"subq\"><span class=\"subq-num\">α)</span> <span class=\"subq-text\">δεν συνάντησε εμπόδια</span></div>\n<div class=\"subq\"><span class=\"subq-num\">β)</span> <span class=\"subq-text\">συνάντησε τα ίδια εμπόδια με την αγροτική</span></div>\n<div class=\"subq\"><span class=\"subq-num\">γ)</span> <span class=\"subq-text\">συνάντησε λιγότερα εμπόδια από την αγροτική</span></div>\n<div class=\"subq\"><span class=\"subq-num\">δ)</span> <span class=\"subq-text\">συνάντησε περισσότερα εμπόδια από την αγροτική.</span></div>\n<div class=\"subq\"><span class=\"subq-num\">5.Η)</span> <span class=\"subq-text\">κυριότερη μεταβολή στην εθνολογική σύσταση, λόγω της άφιξης των προσφύγων του 1922, συνέβη:</span></div>\n<div class=\"subq\"><span class=\"subq-num\">α)</span> <span class=\"subq-text\">στη Θράκη</span></div>\n<div class=\"subq\"><span class=\"subq-num\">β)</span> <span class=\"subq-text\">στην Ήπειρο</span></div>\n<div class=\"subq\"><span class=\"subq-num\">γ)</span> <span class=\"subq-text\">στη Μακεδονία</span></div>\n<div class=\"subq\"><span class=\"subq-num\">δ)</span> <span class=\"subq-text\">στην Κρήτη.</span></div>\n<p class=\"text-content\">(μονάδες 5)</p>\n<div class=\"points-chip\">⭐ 10 μονάδες</div>\n<div class=\"subq\"><span class=\"subq-num\">1.β)</span> <span class=\"subq-text\">Να δώσετε το περιεχόμενο των ακόλουθων όρων: Φεντερασιόν, Πολιτοφυλακή της Κρήτης (1907).</span></div>\n<div class=\"points-chip\">⭐ 7 μονάδες</div>",
